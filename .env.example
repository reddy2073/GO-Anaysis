# Copy this to .env and fill in your keys
# NEVER commit .env to git

ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROK_API_KEY=your_grok_api_key_here_optional
GEMINI_API_KEY=your_gemini_api_key_here

# Required for court verdicts ingestion (IndianKanoon blocks all public scraping)
# Register free at: https://api.indiankanoon.org/
INDIANKANOON_API_TOKEN=your_token_here